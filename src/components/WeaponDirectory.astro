---
import { getOrderedRarityOptions } from "../lib/rarity";
import { getWeaponFilterCounts, type WeaponListItem } from "../lib/weapons";

interface Props {
  weapons: WeaponListItem[];
}

const { weapons } = Astro.props;
const rarityOptions = getOrderedRarityOptions(weapons.map((weapon) => weapon.rarity));
const typeOptions = [...new Set(weapons.map((weapon) => weapon.type))].sort();
const initialFilterCounts = getWeaponFilterCounts(weapons, {
  query: "",
  selectedRarities: [],
  selectedTypes: []
});
---

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@400;500;600;700&display=swap');

  .wd {
    --wd-display: 'Cormorant Garamond', Georgia, serif;
    --wd-body: 'DM Sans', system-ui, sans-serif;
  }

  /* ── Hero ── */
  .wd-hero {
    position: relative;
    overflow: hidden;
    border-radius: 1.25rem;
    padding: 3rem 2.5rem 2.5rem;
    background:
      radial-gradient(ellipse 70% 50% at 80% 20%, color-mix(in srgb, var(--primary) 14%, transparent), transparent),
      radial-gradient(ellipse 50% 60% at 10% 80%, color-mix(in srgb, var(--primary) 8%, transparent), transparent),
      var(--card);
    border: 1px solid var(--border);
  }
  .wd-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%239C92AC' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
  }
  .wd-hero__eyebrow {
    font-family: var(--wd-body);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--primary);
    margin-bottom: 0.5rem;
  }
  .wd-hero__title {
    font-family: var(--wd-display);
    font-size: clamp(2.75rem, 5vw, 4.5rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--card-foreground);
    margin: 0;
  }
  .wd-hero__desc {
    font-family: var(--wd-display);
    font-style: italic;
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--muted-foreground);
    max-width: 36rem;
    margin-top: 0.75rem;
  }
  .wd-hero__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }
  .wd-hero__pill {
    font-family: var(--wd-body);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.4rem 1rem;
    border: 2px solid var(--primary);
    color: var(--primary);
    border-radius: 999px;
    white-space: nowrap;
  }

  /* ── Toolbar ── */
  .wd-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    gap: 1px;
    margin-top: 1.5rem;
    background: var(--border);
    border-radius: 1rem;
    position: relative;
    z-index: 10;
  }
  .wd-toolbar__cell {
    flex: 1 1 12rem;
    background: var(--card);
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
  }
  .wd-toolbar__cell:first-child { border-radius: 1rem 0 0 1rem; }
  .wd-toolbar__cell:last-child  { border-radius: 0 1rem 1rem 0; }
  .wd-toolbar__cell--search { flex: 2 1 16rem; }
  .wd-toolbar__search {
    width: 100%;
    height: 2.25rem;
    border: none;
    background: transparent;
    font-family: var(--wd-body);
    font-size: 0.875rem;
    color: var(--foreground);
    outline: none;
  }
  .wd-toolbar__search::placeholder { color: var(--muted-foreground); }

  /* ── Dropdown triggers ── */
  .wd-dropdown { position: relative; width: 100%; }
  .wd-dropdown__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    height: 2.25rem;
    border: none;
    background: transparent;
    font-family: var(--wd-body);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--foreground);
    cursor: pointer;
    padding: 0;
    transition: color 0.15s;
  }
  .wd-dropdown__btn:hover { color: var(--primary); }
  .wd-dropdown__btn svg { width: 0.875rem; height: 0.875rem; color: var(--muted-foreground); flex-shrink: 0; }
  .wd-dropdown__badge {
    display: none;
    font-size: 0.625rem;
    font-weight: 700;
    line-height: 1;
    padding: 0.2rem 0.4rem;
    border-radius: 999px;
    background: var(--primary);
    color: var(--primary-foreground);
  }
  .wd-dropdown__badge--visible { display: inline-flex; }
  .wd-dropdown__panel {
    display: none;
    position: absolute;
    left: 0;
    top: calc(100% + 0.5rem);
    z-index: 40;
    min-width: 12rem;
    max-height: 20rem;
    overflow-y: auto;
    border-radius: 0.75rem;
    border: 1px solid var(--border);
    background: var(--card);
    box-shadow: 0 8px 24px -4px rgba(0,0,0,0.18);
    padding: 0.375rem;
  }
  .wd-dropdown__panel--open { display: block; }
  .wd-dropdown__option {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.5rem 0.625rem;
    border-radius: 0.5rem;
    font-family: var(--wd-body);
    font-size: 0.8125rem;
    color: var(--foreground);
    cursor: pointer;
    transition: background 0.12s;
  }
  .wd-dropdown__option:hover { background: color-mix(in srgb, var(--primary) 8%, transparent); }
  .wd-dropdown__option input { width: 1rem; height: 1rem; accent-color: var(--primary); flex-shrink: 0; }
  .wd-dropdown__option-left { display: flex; align-items: center; gap: 0.5rem; }
  .wd-dropdown__option-count {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--muted-foreground);
    background: color-mix(in srgb, var(--muted) 60%, transparent);
    padding: 0.15rem 0.4rem;
    border-radius: 0.25rem;
  }
  .wd-dropdown__sep { height: 1px; background: var(--border); margin: 0.25rem 0.5rem; }

  /* ── Nested filter group inside Filters dropdown ── */
  .wd-filter-group { margin: 0; }
  .wd-filter-group + .wd-filter-group { border-top: 1px solid var(--border); margin-top: 0.25rem; padding-top: 0.25rem; }
  .wd-filter-group__toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 0.5rem 0.625rem;
    border: none;
    border-radius: 0.5rem;
    background: transparent;
    font-family: var(--wd-body);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--foreground);
    cursor: pointer;
    transition: background 0.12s;
  }
  .wd-filter-group__toggle:hover { background: color-mix(in srgb, var(--primary) 6%, transparent); }
  .wd-filter-group__toggle-left { display: flex; align-items: center; gap: 0.5rem; }
  .wd-filter-group__toggle-left svg { width: 0.875rem; height: 0.875rem; color: var(--muted-foreground); }
  .wd-filter-group__toggle-right { display: flex; align-items: center; gap: 0.375rem; }
  .wd-filter-group__chevron {
    width: 0.75rem;
    height: 0.75rem;
    color: var(--muted-foreground);
    transition: transform 0.2s;
  }
  .wd-filter-group--open .wd-filter-group__chevron { transform: rotate(180deg); }
  .wd-filter-group__items {
    display: none;
    padding: 0.125rem 0 0.25rem 0.25rem;
  }
  .wd-filter-group--open .wd-filter-group__items { display: block; }

  /* ── Results grid ── */
  .wd-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1px;
    margin-top: 1.5rem;
    background: var(--border);
    border-radius: 1.25rem;
    overflow: hidden;
  }

  .wd-card {
    background: var(--card);
    padding: 1.5rem 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    transition: background 0.2s;
    position: relative;
    flex: 1 1 100%;
  }
  @media (min-width: 640px) { 
    .wd-card { flex: 1 1 calc(50% - 1px); } 
  }
  @media (min-width: 1024px) { 
    .wd-card { flex: 1 1 calc(33.333% - 1px); } 
  }
  .wd-card:hover { background: color-mix(in srgb, var(--primary) 3%, var(--card)); }

  .wd-card__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .wd-card__type {
    font-family: var(--wd-body);
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--primary);
  }
  .wd-card__name {
    font-family: var(--wd-display);
    font-size: 1.375rem;
    font-weight: 700;
    line-height: 1.15;
    color: var(--card-foreground);
    text-decoration: none;
    transition: color 0.15s;
    margin-top: 0.25rem;
    display: block;
  }
  .wd-card__name:hover { color: var(--primary); }
  .wd-card__rarity {
    font-family: var(--wd-body);
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border: 1.5px solid color-mix(in srgb, var(--primary) 40%, var(--border));
    color: var(--primary);
    border-radius: 999px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .wd-card__stats-group {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: color-mix(in srgb, var(--border) 50%, transparent);
    border-radius: 0.5rem;
    overflow: hidden;
  }
  .wd-card__stats-row {
    display: flex;
    gap: 1px;
  }
  .wd-card__stat {
    flex: 1;
    padding: 0.625rem 0.75rem;
    background: color-mix(in srgb, var(--primary) 4%, var(--background));
  }
  .wd-card__stat--full { flex: 1 1 100%; }
  .wd-card__stat-label {
    font-family: var(--wd-body);
    font-size: 0.5625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--muted-foreground);
  }
  .wd-card__stat-value {
    font-family: var(--wd-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--card-foreground);
    line-height: 1;
    margin-top: 0.25rem;
  }
  .wd-card__stat-value--accent { color: var(--primary); }
  .wd-card__stat-value--text {
    font-size: 0.8125rem;
    font-family: var(--wd-body);
    margin-top: 0.35rem;
  }

  .wd-card__link {
    font-family: var(--wd-body);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--muted-foreground);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    transition: color 0.15s;
    margin-top: auto;
  }
  .wd-card__link:hover { color: var(--primary); }
  .wd-card__link svg { width: 0.75rem; height: 0.75rem; transition: transform 0.2s; }
  .wd-card__link:hover svg { transform: translateX(2px); }

  /* ── Empty state ── */
  .wd-empty {
    grid-column: 1 / -1;
    padding: 4rem 2rem;
    text-align: center;
    background: var(--card);
  }
  .wd-empty__text {
    font-family: var(--wd-display);
    font-size: 1.25rem;
    font-style: italic;
    color: var(--muted-foreground);
  }

  /* ── Entrance animations ── */
  @keyframes wd-fade-up {
    from { opacity: 0; transform: translateY(1.25rem); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .wd-anim { animation: wd-fade-up 0.55s cubic-bezier(0.16, 1, 0.3, 1) both; }
  .wd-anim-d1 { animation-delay: 0.08s; }
  .wd-anim-d2 { animation-delay: 0.16s; }
</style>

<section class="wd" data-weapon-directory>

  <!-- ── HERO ── -->
  <div class="wd-hero wd-anim">
    <p class="wd-hero__eyebrow">Primary Source</p>
    <h1 class="wd-hero__title">Weapons</h1>
    <p class="wd-hero__desc">
      Cleaned weapon data from crimsondesert.gg &mdash; instant search, multi-select filters, and numeric sorting for damage values.
    </p>
    <div class="wd-hero__pills">
      <span class="wd-hero__pill"><strong data-count>{initialFilterCounts.total}</strong>&thinsp;results</span>
      <span class="wd-hero__pill">{typeOptions.length} types</span>
      <span class="wd-hero__pill">{rarityOptions.length} rarities</span>
    </div>
  </div>

  <!-- ── TOOLBAR ── -->
  <div class="wd-toolbar wd-anim wd-anim-d1">
    <!-- Search -->
    <div class="wd-toolbar__cell wd-toolbar__cell--search">
      <input type="search" placeholder="Search weapons by name or type…" data-search class="wd-toolbar__search" />
    </div>

    <!-- Filters (nested: Rarity + Type) -->
    <div class="wd-toolbar__cell">
      <div class="wd-dropdown" data-dropdown="filters">
        <button type="button" data-dropdown-btn="filters" class="wd-dropdown__btn">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 0 1-.659 1.591l-5.432 5.432a2.25 2.25 0 0 0-.659 1.591v2.927a2.25 2.25 0 0 1-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 0 0-.659-1.591L3.659 7.409A2.25 2.25 0 0 1 3 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0 1 12 3Z"/></svg>
          Filters
          <span data-dropdown-count="filters" class="wd-dropdown__badge"></span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="margin-left:auto;"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
        </button>
        <div data-dropdown-panel="filters" class="wd-dropdown__panel" style="min-width:14rem;">
          <!-- Rarity sub-group -->
          <div class="wd-filter-group" data-filter-group="rarity">
            <button type="button" class="wd-filter-group__toggle" data-filter-group-toggle="rarity">
              <span class="wd-filter-group__toggle-left">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z"/></svg>
                Rarity
              </span>
              <span class="wd-filter-group__toggle-right">
                <span data-dropdown-count="rarity" class="wd-dropdown__badge"></span>
                <svg class="wd-filter-group__chevron" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
              </span>
            </button>
            <div class="wd-filter-group__items">
              {rarityOptions.map((rarity) => (
                <label class="wd-dropdown__option">
                  <span class="wd-dropdown__option-left">
                    <input type="checkbox" value={rarity} data-rarity />
                    <span style="text-transform:capitalize;">{rarity}</span>
                  </span>
                  <span data-filter-count="rarity" data-filter-value={rarity} class="wd-dropdown__option-count">
                    {initialFilterCounts.rarityCounts[rarity] ?? 0}
                  </span>
                </label>
              ))}
            </div>
          </div>
          <!-- Type sub-group -->
          <div class="wd-filter-group" data-filter-group="type">
            <button type="button" class="wd-filter-group__toggle" data-filter-group-toggle="type">
              <span class="wd-filter-group__toggle-left">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z"/></svg>
                Type
              </span>
              <span class="wd-filter-group__toggle-right">
                <span data-dropdown-count="type" class="wd-dropdown__badge"></span>
                <svg class="wd-filter-group__chevron" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
              </span>
            </button>
            <div class="wd-filter-group__items">
              {typeOptions.map((type) => (
                <label class="wd-dropdown__option">
                  <span class="wd-dropdown__option-left">
                    <input type="checkbox" value={type} data-type />
                    <span>{type}</span>
                  </span>
                  <span data-filter-count="type" data-filter-value={type} class="wd-dropdown__option-count">
                    {initialFilterCounts.typeCounts[type] ?? 0}
                  </span>
                </label>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Sort -->
    <div class="wd-toolbar__cell">
      <div class="wd-dropdown" data-dropdown="sort">
        <button type="button" data-dropdown-btn="sort" class="wd-dropdown__btn">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7.5 7.5 3m0 0L12 7.5M7.5 3v13.5m13.5 0L16.5 21m0 0L12 16.5m4.5 4.5V7.5"/></svg>
          <span data-sort-label>Name A-Z</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="margin-left:auto;"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
        </button>
        <div data-dropdown-panel="sort" class="wd-dropdown__panel">
          <label class="wd-dropdown__option"><span class="wd-dropdown__option-left"><input type="radio" name="sort" value="name-asc" data-sort-option checked /><span>Name A-Z</span></span></label>
          <label class="wd-dropdown__option"><span class="wd-dropdown__option-left"><input type="radio" name="sort" value="name-desc" data-sort-option /><span>Name Z-A</span></span></label>
          <div class="wd-dropdown__sep"></div>
          <label class="wd-dropdown__option"><span class="wd-dropdown__option-left"><input type="radio" name="sort" value="baseDamage-desc" data-sort-option /><span>Base Damage ↓</span></span></label>
          <label class="wd-dropdown__option"><span class="wd-dropdown__option-left"><input type="radio" name="sort" value="baseDamage-asc" data-sort-option /><span>Base Damage ↑</span></span></label>
          <div class="wd-dropdown__sep"></div>
          <label class="wd-dropdown__option"><span class="wd-dropdown__option-left"><input type="radio" name="sort" value="finalDamage-desc" data-sort-option /><span>Final Damage ↓</span></span></label>
          <label class="wd-dropdown__option"><span class="wd-dropdown__option-left"><input type="radio" name="sort" value="finalDamage-asc" data-sort-option /><span>Final Damage ↑</span></span></label>
          <div class="wd-dropdown__sep"></div>
          <label class="wd-dropdown__option"><span class="wd-dropdown__option-left"><input type="radio" name="sort" value="rarity-asc" data-sort-option /><span>Rarity Low→High</span></span></label>
          <label class="wd-dropdown__option"><span class="wd-dropdown__option-left"><input type="radio" name="sort" value="rarity-desc" data-sort-option /><span>Rarity High→Low</span></span></label>
        </div>
      </div>
    </div>
  </div>

  <!-- ── RESULTS GRID ── -->
  <div class="wd-grid wd-anim wd-anim-d2" data-results>
    {weapons.map((weapon) => (
      <article
        class="wd-card"
        data-card
        data-name={weapon.name.toLowerCase()}
        data-rarity={weapon.rarity}
        data-type={weapon.type}
        data-base-damage={weapon.stats.baseDamage ?? -1}
        data-final-damage={weapon.stats.finalDamage ?? -1}
      >
        <div class="wd-card__top">
          <div>
            <p class="wd-card__type">{weapon.typeLabel}</p>
            <a href={`/weapon/${weapon.slug}`} class="wd-card__name">{weapon.name}</a>
          </div>
          <span class="wd-card__rarity">{weapon.rarity}</span>
        </div>

        <div class="wd-card__stats-group">
          <div class="wd-card__stats-row">
            <div class="wd-card__stat wd-card__stat--full">
              <div class="wd-card__stat-label">Type</div>
              <div class="wd-card__stat-value wd-card__stat-value--text">{weapon.type}</div>
            </div>
          </div>
          <div class="wd-card__stats-row">
            <div class="wd-card__stat">
              <div class="wd-card__stat-label">Base</div>
              <div class="wd-card__stat-value">{weapon.stats.baseDamage ?? "—"}</div>
            </div>
            <div class="wd-card__stat">
              <div class="wd-card__stat-label">Final</div>
              <div class="wd-card__stat-value wd-card__stat-value--accent">{weapon.stats.finalDamage ?? "—"}</div>
            </div>
          </div>
        </div>

        <a href={`/weapon/${weapon.slug}`} class="wd-card__link">
          View details
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
          </svg>
        </a>
      </article>
    ))}
  </div>
</section>

<script type="application/json" id="weapon-directory-data" set:html={JSON.stringify(weapons)} />

<script>
  const root = document.querySelector("[data-weapon-directory]");
  const dataNode = document.getElementById("weapon-directory-data");

  if (root instanceof HTMLElement && dataNode?.textContent) {
    const weapons = JSON.parse(dataNode.textContent);
    const searchInput = root.querySelector("[data-search]");
    const sortInputs = [...root.querySelectorAll("[data-sort-option]")];
    const sortLabel = root.querySelector("[data-sort-label]");
    const rarityInputs = [...root.querySelectorAll("[data-rarity]")];
    const typeInputs = [...root.querySelectorAll("[data-type]")];
    const results = root.querySelector("[data-results]");
    const countNode = root.querySelector("[data-count]");
    const rarityCountNodes = [...root.querySelectorAll('[data-filter-count="rarity"]')];
    const typeCountNodes = [...root.querySelectorAll('[data-filter-count="type"]')];

    const compareText = (left: string, right: string) => left.localeCompare(right);
    const compareNumber = (left: number, right: number) => left - right;

    const getFilterCounts = ({
      query,
      selectedRarities,
      selectedTypes
    }: {
      query: string;
      selectedRarities: string[];
      selectedTypes: string[];
    }) => {
      const normalizedQuery = query.trim().toLowerCase();
      const queryMatches = weapons.filter((weapon: any) => {
        if (normalizedQuery.length === 0) {
          return true;
        }

        return (
          weapon.name.toLowerCase().includes(normalizedQuery) ||
          weapon.type.toLowerCase().includes(normalizedQuery)
        );
      });
      const rarityPool = queryMatches.filter(
        (weapon: any) =>
          selectedTypes.length === 0 || selectedTypes.includes(weapon.type)
      );
      const typePool = queryMatches.filter(
        (weapon: any) =>
          selectedRarities.length === 0 || selectedRarities.includes(weapon.rarity)
      );

      return {
        total: queryMatches.filter(
          (weapon: any) =>
            (selectedRarities.length === 0 || selectedRarities.includes(weapon.rarity)) &&
            (selectedTypes.length === 0 || selectedTypes.includes(weapon.type))
        ).length,
        rarityCounts: Object.fromEntries(
          rarityPool.map((weapon: any) => weapon.rarity).map((rarity: string, _: number, all: string[]) => [
            rarity,
            rarityPool.filter((weapon: any) => weapon.rarity === rarity).length
          ]).filter(
            ([rarity]: [string, number], index: number, all: [string, number][]) =>
              all.findIndex(([value]) => value === rarity) === index
          )
        ),
        typeCounts: Object.fromEntries(
          typePool.map((weapon: any) => weapon.type).map((type: string, _: number, all: string[]) => [
            type,
            typePool.filter((weapon: any) => weapon.type === type).length
          ]).filter(
            ([type]: [string, number], index: number, all: [string, number][]) =>
              all.findIndex(([value]) => value === type) === index
          )
        )
      };
    };

    const getSelectedValues = (inputs: Element[]) =>
      inputs.filter((input) => (input as HTMLInputElement).checked).map((input) => (input as HTMLInputElement).value);

    const renderCard = (weapon: any) => `
      <article class="wd-card">
        <div class="wd-card__top">
          <div>
            <p class="wd-card__type">${weapon.typeLabel}</p>
            <a href="/weapon/${weapon.slug}" class="wd-card__name">${weapon.name}</a>
          </div>
          <span class="wd-card__rarity">${weapon.rarity}</span>
        </div>
        <div class="wd-card__stats-group">
          <div class="wd-card__stats-row">
            <div class="wd-card__stat wd-card__stat--full">
              <div class="wd-card__stat-label">Type</div>
              <div class="wd-card__stat-value wd-card__stat-value--text">${weapon.type}</div>
            </div>
          </div>
          <div class="wd-card__stats-row">
            <div class="wd-card__stat">
              <div class="wd-card__stat-label">Base</div>
              <div class="wd-card__stat-value">${weapon.stats.baseDamage ?? "—"}</div>
            </div>
            <div class="wd-card__stat">
              <div class="wd-card__stat-label">Final</div>
              <div class="wd-card__stat-value wd-card__stat-value--accent">${weapon.stats.finalDamage ?? "—"}</div>
            </div>
          </div>
        </div>
        <a href="/weapon/${weapon.slug}" class="wd-card__link">
          View details
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
          </svg>
        </a>
      </article>`;

    const render = () => {
      const query = searchInput instanceof HTMLInputElement ? searchInput.value.trim().toLowerCase() : "";
      const selectedRarities = getSelectedValues(rarityInputs);
      const selectedTypes = getSelectedValues(typeInputs);
      const sortValue = sortInputs.find((i) => (i as HTMLInputElement).checked)
        ? (sortInputs.find((i) => (i as HTMLInputElement).checked) as HTMLInputElement).value
        : "name-asc";
      const filterCounts = getFilterCounts({
        query,
        selectedRarities,
        selectedTypes
      });

      const filtered = weapons.filter((weapon: any) => {
        const matchesQuery =
          query.length === 0 ||
          weapon.name.toLowerCase().includes(query) ||
          weapon.type.toLowerCase().includes(query);
        const matchesRarity =
          selectedRarities.length === 0 || selectedRarities.includes(weapon.rarity);
        const matchesType = selectedTypes.length === 0 || selectedTypes.includes(weapon.type);

        return matchesQuery && matchesRarity && matchesType;
      });

      filtered.sort((left: any, right: any) => {
        switch (sortValue) {
          case "name-desc":
            return compareText(right.name, left.name);
          case "baseDamage-desc":
            return compareNumber((right.stats.baseDamage ?? -1), (left.stats.baseDamage ?? -1));
          case "baseDamage-asc":
            return compareNumber((left.stats.baseDamage ?? -1), (right.stats.baseDamage ?? -1));
          case "finalDamage-desc":
            return compareNumber((right.stats.finalDamage ?? -1), (left.stats.finalDamage ?? -1));
          case "finalDamage-asc":
            return compareNumber((left.stats.finalDamage ?? -1), (right.stats.finalDamage ?? -1));
          case "rarity-asc":
            return compareRarity(left.rarity, right.rarity);
          case "rarity-desc":
            return compareRarity(right.rarity, left.rarity);
          default:
            return compareText(left.name, right.name);
        }
      });

      if (countNode) {
        countNode.textContent = String(filterCounts.total);
      }

      rarityCountNodes.forEach((node) => {
        if (!(node instanceof HTMLElement)) {
          return;
        }

        const value = node.dataset.filterValue ?? "";
        node.textContent = String(filterCounts.rarityCounts[value] ?? 0);
      });

      typeCountNodes.forEach((node) => {
        if (!(node instanceof HTMLElement)) {
          return;
        }

        const value = node.dataset.filterValue ?? "";
        node.textContent = String(filterCounts.typeCounts[value] ?? 0);
      });

      if (results instanceof HTMLElement) {
        results.innerHTML = filtered.map((weapon: any) => renderCard(weapon)).join("");
      }
    };

    searchInput?.addEventListener("input", render);
    rarityInputs.forEach((input) => input.addEventListener("change", render));
    typeInputs.forEach((input) => input.addEventListener("change", render));

    // Update a badge count helper
    function updateBadge(badge: Element | null, count: number) {
      if (!badge) return;
      if (count > 0) {
        badge.textContent = String(count);
        badge.classList.add("wd-dropdown__badge--visible");
      } else {
        badge.classList.remove("wd-dropdown__badge--visible");
      }
    }

    // Nested filter-group accordion toggles
    root.querySelectorAll("[data-filter-group-toggle]").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const group = (btn as HTMLElement).closest(".wd-filter-group");
        if (group) group.classList.toggle("wd-filter-group--open");
      });
    });

    // Update sub-badges (rarity/type) and the combined filters badge on change
    const filtersBadge = root.querySelector('[data-dropdown-count="filters"]');
    const rarityBadge = root.querySelector('[data-dropdown-count="rarity"]');
    const typeBadge = root.querySelector('[data-dropdown-count="type"]');

    function updateFilterBadges() {
      const rarityCount = rarityInputs.filter((i) => (i as HTMLInputElement).checked).length;
      const typeCount = typeInputs.filter((i) => (i as HTMLInputElement).checked).length;
      updateBadge(rarityBadge, rarityCount);
      updateBadge(typeBadge, typeCount);
      updateBadge(filtersBadge, rarityCount + typeCount);
    }

    rarityInputs.forEach((input) => input.addEventListener("change", updateFilterBadges));
    typeInputs.forEach((input) => input.addEventListener("change", updateFilterBadges));

    // Top-level dropdown toggle (filters + sort)
    function setupDropdown(name: string, inputs: Element[], labelSelector?: string) {
      const btn = root.querySelector(`[data-dropdown-btn="${name}"]`);
      const panel = root.querySelector(`[data-dropdown-panel="${name}"]`);
      if (!btn || !panel) return;

      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        root.querySelectorAll("[data-dropdown-panel]").forEach((p) => {
          if (p !== panel) p.classList.remove("wd-dropdown__panel--open");
        });
        panel.classList.toggle("wd-dropdown__panel--open");
      });

      panel.addEventListener("click", (e) => e.stopPropagation());

      if (labelSelector) {
        inputs.forEach((input) => {
          input.addEventListener("change", () => {
            const selected = inputs.find((i) => (i as HTMLInputElement).checked) as HTMLInputElement;
            const label = root.querySelector(labelSelector);
            if (label && selected) {
              label.textContent = selected.parentElement?.textContent?.trim() ?? "";
            }
            render();
          });
        });
      }
    }

    setupDropdown("filters", [...rarityInputs, ...typeInputs]);
    setupDropdown("sort", sortInputs, "[data-sort-label]");

    document.addEventListener("click", () => {
      root.querySelectorAll("[data-dropdown-panel]").forEach((p) => p.classList.remove("wd-dropdown__panel--open"));
    });
  }
</script>
