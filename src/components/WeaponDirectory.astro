---
import { getOrderedRarityOptions } from "../lib/rarity";
import { getWeaponFilterCounts, type WeaponListItem } from "../lib/weapons";
import "../styles/weapon-directory.css";

interface Props {
  weapons: WeaponListItem[];
}

const { weapons } = Astro.props;
const rarityOptions = getOrderedRarityOptions(weapons.map((weapon) => weapon.rarity));
const typeOptions = [...new Set(weapons.map((weapon) => weapon.type))].sort();
const initialFilterCounts = getWeaponFilterCounts(weapons, {
  query: "",
  selectedRarities: [],
  selectedTypes: []
});
---

<section class="wd" data-weapon-directory>

  <!-- ── HERO ── -->
  <div class="wd-hero wd-anim">
    <p class="wd-hero__eyebrow">Primary Source</p>
    <h1 class="wd-hero__title">Weapons</h1>
    <p class="wd-hero__desc">
      Cleaned weapon data from crimsondesert.gg &mdash; instant search, multi-select filters, and numeric sorting for damage values.
    </p>
    <div class="wd-hero__pills">
      <span class="wd-hero__pill"><strong data-count>{initialFilterCounts.total}</strong>&thinsp;results</span>
      <span class="wd-hero__pill">{typeOptions.length} types</span>
      <span class="wd-hero__pill">{rarityOptions.length} rarities</span>
    </div>
  </div>

  <!-- ── TOOLBAR ── -->
  <div class="wd-toolbar wd-anim wd-anim-d1">
    <!-- Search -->
    <div class="wd-toolbar__cell wd-toolbar__cell--search">
      <input type="search" placeholder="Search weapons by name or type…" data-search class="wd-toolbar__search" />
    </div>

    <!-- Filters (nested: Rarity + Type) -->
    <div class="wd-toolbar__cell">
      <div class="wd-dropdown" data-dropdown="filters">
        <button type="button" data-dropdown-btn="filters" class="wd-dropdown__btn">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 0 1-.659 1.591l-5.432 5.432a2.25 2.25 0 0 0-.659 1.591v2.927a2.25 2.25 0 0 1-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 0 0-.659-1.591L3.659 7.409A2.25 2.25 0 0 1 3 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0 1 12 3Z"/></svg>
          Filters
          <span data-dropdown-count="filters" class="wd-dropdown__badge"></span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="margin-left:auto;"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
        </button>
        <div data-dropdown-panel="filters" class="wd-dropdown__panel" style="min-width:14rem;">
          <!-- Rarity sub-group -->
          <div class="wd-filter-group" data-filter-group="rarity">
            <button type="button" class="wd-filter-group__toggle" data-filter-group-toggle="rarity">
              <span class="wd-filter-group__toggle-left">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z"/></svg>
                Rarity
              </span>
              <span class="wd-filter-group__toggle-right">
                <span data-dropdown-count="rarity" class="wd-dropdown__badge"></span>
                <svg class="wd-filter-group__chevron" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
              </span>
            </button>
            <div class="wd-filter-group__items">
              {rarityOptions.map((rarity) => (
                <label class="wd-dropdown__option">
                  <span class="wd-dropdown__option-left">
                    <input type="checkbox" value={rarity} data-rarity />
                    <span style="text-transform:capitalize;">{rarity}</span>
                  </span>
                  <span data-filter-count="rarity" data-filter-value={rarity} class="wd-dropdown__option-count">
                    {initialFilterCounts.rarityCounts[rarity] ?? 0}
                  </span>
                </label>
              ))}
            </div>
          </div>
          <!-- Type sub-group -->
          <div class="wd-filter-group" data-filter-group="type">
            <button type="button" class="wd-filter-group__toggle" data-filter-group-toggle="type">
              <span class="wd-filter-group__toggle-left">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z"/></svg>
                Type
              </span>
              <span class="wd-filter-group__toggle-right">
                <span data-dropdown-count="type" class="wd-dropdown__badge"></span>
                <svg class="wd-filter-group__chevron" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
              </span>
            </button>
            <div class="wd-filter-group__items">
              {typeOptions.map((type) => (
                <label class="wd-dropdown__option">
                  <span class="wd-dropdown__option-left">
                    <input type="checkbox" value={type} data-type />
                    <span>{type}</span>
                  </span>
                  <span data-filter-count="type" data-filter-value={type} class="wd-dropdown__option-count">
                    {initialFilterCounts.typeCounts[type] ?? 0}
                  </span>
                </label>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Sort -->
    <div class="wd-toolbar__cell">
      <div class="wd-dropdown" data-dropdown="sort">
        <button type="button" data-dropdown-btn="sort" class="wd-dropdown__btn">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7.5 7.5 3m0 0L12 7.5M7.5 3v13.5m13.5 0L16.5 21m0 0L12 16.5m4.5 4.5V7.5"/></svg>
          <span data-sort-label>Name A-Z</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="margin-left:auto;"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
        </button>
        <div data-dropdown-panel="sort" class="wd-dropdown__panel">
          <label class="wd-dropdown__option"><span class="wd-dropdown__option-left"><input type="radio" name="sort" value="name-asc" data-sort-option checked /><span>Name A-Z</span></span></label>
          <label class="wd-dropdown__option"><span class="wd-dropdown__option-left"><input type="radio" name="sort" value="name-desc" data-sort-option /><span>Name Z-A</span></span></label>
          <div class="wd-dropdown__sep"></div>
          <label class="wd-dropdown__option"><span class="wd-dropdown__option-left"><input type="radio" name="sort" value="baseDamage-desc" data-sort-option /><span>Base Damage ↓</span></span></label>
          <label class="wd-dropdown__option"><span class="wd-dropdown__option-left"><input type="radio" name="sort" value="baseDamage-asc" data-sort-option /><span>Base Damage ↑</span></span></label>
          <div class="wd-dropdown__sep"></div>
          <label class="wd-dropdown__option"><span class="wd-dropdown__option-left"><input type="radio" name="sort" value="finalDamage-desc" data-sort-option /><span>Final Damage ↓</span></span></label>
          <label class="wd-dropdown__option"><span class="wd-dropdown__option-left"><input type="radio" name="sort" value="finalDamage-asc" data-sort-option /><span>Final Damage ↑</span></span></label>
          <div class="wd-dropdown__sep"></div>
          <label class="wd-dropdown__option"><span class="wd-dropdown__option-left"><input type="radio" name="sort" value="rarity-asc" data-sort-option /><span>Rarity Low→High</span></span></label>
          <label class="wd-dropdown__option"><span class="wd-dropdown__option-left"><input type="radio" name="sort" value="rarity-desc" data-sort-option /><span>Rarity High→Low</span></span></label>
        </div>
      </div>
    </div>
  </div>

  <!-- ── RESULTS GRID ── -->
  <div class="wd-grid wd-anim wd-anim-d2" data-results>
    {weapons.map((weapon) => (
      <article
        class="wd-card"
        data-card
        data-name={weapon.name.toLowerCase()}
        data-rarity={weapon.rarity}
        data-type={weapon.type}
        data-base-damage={weapon.stats.baseDamage ?? -1}
        data-final-damage={weapon.stats.finalDamage ?? -1}
      >
        <div class="wd-card__top">
          <div>
            <p class="wd-card__type">{weapon.typeLabel}</p>
            <a href={`/weapon/${weapon.slug}`} class="wd-card__name">{weapon.name}</a>
          </div>
          <span class="wd-card__rarity">{weapon.rarity}</span>
        </div>

        <div class="wd-card__stats-group">
          <div class="wd-card__stats-row">
            <div class="wd-card__stat wd-card__stat--full">
              <div class="wd-card__stat-label">Type</div>
              <div class="wd-card__stat-value wd-card__stat-value--text">{weapon.type}</div>
            </div>
          </div>
          <div class="wd-card__stats-row">
            <div class="wd-card__stat">
              <div class="wd-card__stat-label">Base</div>
              <div class="wd-card__stat-value">{weapon.stats.baseDamage ?? "—"}</div>
            </div>
            <div class="wd-card__stat">
              <div class="wd-card__stat-label">Final</div>
              <div class="wd-card__stat-value wd-card__stat-value--accent">{weapon.stats.finalDamage ?? "—"}</div>
            </div>
          </div>
        </div>

        <a href={`/weapon/${weapon.slug}`} class="wd-card__link">
          View details
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
          </svg>
        </a>
      </article>
    ))}
  </div>
</section>

<script type="application/json" id="weapon-directory-data" set:html={JSON.stringify(weapons)} />

<script>
  import "../lib/weapon-directory.ts";
</script>
