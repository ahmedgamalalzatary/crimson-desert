---
import { getOrderedRarityOptions } from "../lib/rarity";
import { getWeaponFilterCounts, type WeaponListItem } from "../lib/weapons";

interface Props {
  weapons: WeaponListItem[];
}

const { weapons } = Astro.props;
const rarityOptions = getOrderedRarityOptions(weapons.map((weapon) => weapon.rarity));
const typeOptions = [...new Set(weapons.map((weapon) => weapon.type))].sort();
const initialFilterCounts = getWeaponFilterCounts(weapons, {
  query: "",
  selectedRarities: [],
  selectedTypes: []
});
---

<section class="grid gap-6" data-weapon-directory>
  <div class="rounded-2xl border border-border bg-card p-6 shadow-sm">
    <p class="mb-1 font-sans text-xs font-medium uppercase tracking-widest text-primary">
      Primary Source
    </p>
    <h1 class="font-serif text-4xl font-bold leading-tight tracking-tight text-card-foreground sm:text-5xl">
      Weapons
    </h1>
    <p class="mt-2 max-w-2xl text-muted-foreground">
      Cleaned weapon data from <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-sm">crimsondesert.gg</code>. Search is instant, filters are
      multi-select, and sorting stays numeric for damage values.
    </p>
    <div class="mt-4 flex flex-wrap gap-2">
      <span class="inline-flex items-center rounded-full border border-border bg-primary/10 px-3 py-1.5 font-sans text-sm font-medium text-primary">
        <strong data-count>{initialFilterCounts.total}</strong>&nbsp;results
      </span>
      <span class="inline-flex items-center rounded-full border border-border bg-primary/10 px-3 py-1.5 font-sans text-sm font-medium text-primary">
        {typeOptions.length} weapon types
      </span>
      <span class="inline-flex items-center rounded-full border border-border bg-primary/10 px-3 py-1.5 font-sans text-sm font-medium text-primary">
        {rarityOptions.length} rarity tiers
      </span>
    </div>
  </div>

  <div class="flex flex-col gap-3 rounded-2xl border border-border bg-card p-4 shadow-sm sm:flex-row sm:items-end">
    <div class="flex-1 font-sans">
      <input
        type="search"
        placeholder="Search weapons..."
        data-search
        class="h-10 w-full rounded-lg border border-border bg-input px-3 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring"
      />
    </div>

    <div class="relative font-sans" data-dropdown="rarity">
      <button
        type="button"
        data-dropdown-btn="rarity"
        class="inline-flex h-10 items-center gap-1.5 rounded-lg border border-border bg-input px-3 text-sm text-foreground transition-all hover:border-primary/40 hover:bg-accent"
      >
        <svg class="size-3.5 shrink-0 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z"/></svg>
        Rarity
        <span data-dropdown-count="rarity" class="hidden rounded-full bg-primary px-1.5 py-0.5 text-[0.65rem] font-semibold leading-none text-primary-foreground"></span>
        <svg class="size-3.5 shrink-0 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
      </button>
      <div data-dropdown-panel="rarity" class="absolute left-0 z-30 mt-1.5 hidden w-44 overflow-hidden rounded-xl border border-border/80 bg-card shadow-xl shadow-black/20">
        <div class="max-h-40 overflow-y-auto p-1.5">
          {rarityOptions.map((rarity) => (
            <label class="flex cursor-pointer items-center justify-between gap-2.5 rounded-lg px-2.5 py-2 text-sm text-foreground transition-all hover:bg-accent">
              <span class="flex items-center gap-2.5">
              <input type="checkbox" value={rarity} data-rarity class="size-4 shrink-0 rounded border-border/60 accent-primary" />
              <span class="capitalize">{rarity}</span>
              </span>
              <span
                data-filter-count="rarity"
                data-filter-value={rarity}
                class="rounded-full bg-muted px-2 py-0.5 text-[0.7rem] font-medium text-muted-foreground"
              >
                {initialFilterCounts.rarityCounts[rarity] ?? 0}
              </span>
            </label>
          ))}
        </div>
      </div>
    </div>

    <div class="relative font-sans" data-dropdown="type">
      <button
        type="button"
        data-dropdown-btn="type"
        class="inline-flex h-10 items-center gap-1.5 rounded-lg border border-border bg-input px-3 text-sm text-foreground transition-all hover:border-primary/40 hover:bg-accent"
      >
        <svg class="size-3.5 shrink-0 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z"/></svg>
        Type
        <span data-dropdown-count="type" class="hidden rounded-full bg-primary px-1.5 py-0.5 text-[0.65rem] font-semibold leading-none text-primary-foreground"></span>
        <svg class="size-3.5 shrink-0 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
      </button>
      <div data-dropdown-panel="type" class="absolute left-0 z-30 mt-1.5 hidden w-48 overflow-hidden rounded-xl border border-border/80 bg-card shadow-xl shadow-black/20">
        <div class="max-h-40 overflow-y-auto p-1.5">
          {typeOptions.map((type) => (
            <label class="flex cursor-pointer items-center justify-between gap-2.5 rounded-lg px-2.5 py-2 text-sm text-foreground transition-all hover:bg-accent">
              <span class="flex items-center gap-2.5">
              <input type="checkbox" value={type} data-type class="size-4 shrink-0 rounded border-border/60 accent-primary" />
              <span>{type}</span>
              </span>
              <span
                data-filter-count="type"
                data-filter-value={type}
                class="rounded-full bg-muted px-2 py-0.5 text-[0.7rem] font-medium text-muted-foreground"
              >
                {initialFilterCounts.typeCounts[type] ?? 0}
              </span>
            </label>
          ))}
        </div>
      </div>
    </div>

    <div class="relative font-sans" data-dropdown="sort">
      <button
        type="button"
        data-dropdown-btn="sort"
        class="inline-flex h-10 items-center gap-1.5 rounded-lg border border-border bg-input px-3 text-sm text-foreground transition-all hover:border-primary/40 hover:bg-accent"
      >
        <svg class="size-3.5 shrink-0 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7.5 7.5 3m0 0L12 7.5M7.5 3v13.5m13.5 0L16.5 21m0 0L12 16.5m4.5 4.5V7.5"/></svg>
        <span data-sort-label>Name A-Z</span>
        <svg class="size-3.5 shrink-0 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
      </button>
      <div data-dropdown-panel="sort" class="absolute left-0 z-30 mt-1.5 hidden w-52 overflow-hidden rounded-xl border border-border/80 bg-card shadow-xl shadow-black/20">
        <div class="max-h-40 overflow-y-auto p-1.5">
          <label class="flex cursor-pointer items-center gap-2.5 rounded-lg px-2.5 py-2 text-sm text-foreground transition-all hover:bg-accent">
            <input type="radio" name="sort" value="name-asc" data-sort-option class="size-4 shrink-0 accent-primary" checked />
            Name A-Z
          </label>
          <label class="flex cursor-pointer items-center gap-2.5 rounded-lg px-2.5 py-2 text-sm text-foreground transition-all hover:bg-accent">
            <input type="radio" name="sort" value="name-desc" data-sort-option class="size-4 shrink-0 accent-primary" />
            Name Z-A
          </label>
          <div class="my-1 h-px bg-border/60"></div>
          <label class="flex cursor-pointer items-center gap-2.5 rounded-lg px-2.5 py-2 text-sm text-foreground transition-all hover:bg-accent">
            <input type="radio" name="sort" value="baseDamage-desc" data-sort-option class="size-4 shrink-0 accent-primary" />
            Base Damage ↓
          </label>
          <label class="flex cursor-pointer items-center gap-2.5 rounded-lg px-2.5 py-2 text-sm text-foreground transition-all hover:bg-accent">
            <input type="radio" name="sort" value="baseDamage-asc" data-sort-option class="size-4 shrink-0 accent-primary" />
            Base Damage ↑
          </label>
          <div class="my-1 h-px bg-border/60"></div>
          <label class="flex cursor-pointer items-center gap-2.5 rounded-lg px-2.5 py-2 text-sm text-foreground transition-all hover:bg-accent">
            <input type="radio" name="sort" value="finalDamage-desc" data-sort-option class="size-4 shrink-0 accent-primary" />
            Final Damage ↓
          </label>
          <label class="flex cursor-pointer items-center gap-2.5 rounded-lg px-2.5 py-2 text-sm text-foreground transition-all hover:bg-accent">
            <input type="radio" name="sort" value="finalDamage-asc" data-sort-option class="size-4 shrink-0 accent-primary" />
            Final Damage ↑
          </label>
          <div class="my-1 h-px bg-border/60"></div>
          <label class="flex cursor-pointer items-center gap-2.5 rounded-lg px-2.5 py-2 text-sm text-foreground transition-all hover:bg-accent">
            <input type="radio" name="sort" value="rarity-asc" data-sort-option class="size-4 shrink-0 accent-primary" />
            Rarity Low→High
          </label>
          <label class="flex cursor-pointer items-center gap-2.5 rounded-lg px-2.5 py-2 text-sm text-foreground transition-all hover:bg-accent">
            <input type="radio" name="sort" value="rarity-desc" data-sort-option class="size-4 shrink-0 accent-primary" />
            Rarity High→Low
          </label>
        </div>
      </div>
    </div>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3" data-results>
    {weapons.map((weapon) => (
      <article
        class="group flex flex-col gap-4 rounded-xl border border-border bg-card p-5 shadow-sm transition-all hover:border-primary/30 hover:shadow-md"
        data-card
        data-name={weapon.name.toLowerCase()}
        data-rarity={weapon.rarity}
        data-type={weapon.type}
        data-base-damage={weapon.stats.baseDamage ?? -1}
        data-final-damage={weapon.stats.finalDamage ?? -1}
      >
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="font-sans text-[0.7rem] font-medium uppercase tracking-widest text-primary">
              {weapon.typeLabel}
            </p>
            <a href={`/weapon/${weapon.slug}`} class="mt-1 block font-serif text-xl font-semibold text-card-foreground transition-colors hover:text-primary">
              {weapon.name}
            </a>
          </div>
          <span class="shrink-0 rounded-full bg-primary/10 px-2.5 py-1 font-sans text-[0.7rem] font-medium uppercase tracking-wider text-primary">
            {weapon.rarity}
          </span>
        </div>

        <dl class="grid grid-cols-2 gap-3">
          <div class="border-t border-border pt-3">
            <dt class="font-sans text-xs uppercase text-muted-foreground">Base</dt>
            <dd class="mt-0.5 text-lg font-semibold text-card-foreground">{weapon.stats.baseDamage ?? "N/A"}</dd>
          </div>
          <div class="border-t border-border pt-3">
            <dt class="font-sans text-xs uppercase text-muted-foreground">Final</dt>
            <dd class="mt-0.5 text-lg font-semibold text-card-foreground">{weapon.stats.finalDamage ?? "N/A"}</dd>
          </div>
          <div class="border-t border-border pt-3">
            <dt class="font-sans text-xs uppercase text-muted-foreground">Type</dt>
            <dd class="mt-0.5 text-sm text-card-foreground">{weapon.type}</dd>
          </div>
          <div class="border-t border-border pt-3">
            <dt class="font-sans text-xs uppercase text-muted-foreground">Page</dt>
            <dd class="mt-0.5 text-sm text-card-foreground">Full details</dd>
          </div>
        </dl>

        <a
          href={`/weapon/${weapon.slug}`}
          class="mt-auto inline-flex items-center gap-1 font-sans text-sm font-medium text-primary transition-colors hover:text-primary/80"
        >
          Open weapon page
          <svg class="size-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m9 5 7 7-7 7" />
          </svg>
        </a>
      </article>
    ))}
  </div>
</section>

<script type="application/json" id="weapon-directory-data" set:html={JSON.stringify(weapons)} />

<script>
  const root = document.querySelector("[data-weapon-directory]");
  const dataNode = document.getElementById("weapon-directory-data");

  if (root instanceof HTMLElement && dataNode?.textContent) {
    const weapons = JSON.parse(dataNode.textContent);
    const searchInput = root.querySelector("[data-search]");
    const sortInputs = [...root.querySelectorAll("[data-sort-option]")];
    const sortLabel = root.querySelector("[data-sort-label]");
    const rarityInputs = [...root.querySelectorAll("[data-rarity]")];
    const typeInputs = [...root.querySelectorAll("[data-type]")];
    const results = root.querySelector("[data-results]");
    const countNode = root.querySelector("[data-count]");
    const rarityCountNodes = [...root.querySelectorAll('[data-filter-count="rarity"]')];
    const typeCountNodes = [...root.querySelectorAll('[data-filter-count="type"]')];

    const compareText = (left: string, right: string) => left.localeCompare(right);
    const compareNumber = (left: number, right: number) => left - right;

    const getFilterCounts = ({
      query,
      selectedRarities,
      selectedTypes
    }: {
      query: string;
      selectedRarities: string[];
      selectedTypes: string[];
    }) => {
      const normalizedQuery = query.trim().toLowerCase();
      const queryMatches = weapons.filter((weapon: any) => {
        if (normalizedQuery.length === 0) {
          return true;
        }

        return (
          weapon.name.toLowerCase().includes(normalizedQuery) ||
          weapon.type.toLowerCase().includes(normalizedQuery)
        );
      });
      const rarityPool = queryMatches.filter(
        (weapon: any) =>
          selectedTypes.length === 0 || selectedTypes.includes(weapon.type)
      );
      const typePool = queryMatches.filter(
        (weapon: any) =>
          selectedRarities.length === 0 || selectedRarities.includes(weapon.rarity)
      );

      return {
        total: queryMatches.filter(
          (weapon: any) =>
            (selectedRarities.length === 0 || selectedRarities.includes(weapon.rarity)) &&
            (selectedTypes.length === 0 || selectedTypes.includes(weapon.type))
        ).length,
        rarityCounts: Object.fromEntries(
          rarityPool.map((weapon: any) => weapon.rarity).map((rarity: string, _: number, all: string[]) => [
            rarity,
            rarityPool.filter((weapon: any) => weapon.rarity === rarity).length
          ]).filter(
            ([rarity]: [string, number], index: number, all: [string, number][]) =>
              all.findIndex(([value]) => value === rarity) === index
          )
        ),
        typeCounts: Object.fromEntries(
          typePool.map((weapon: any) => weapon.type).map((type: string, _: number, all: string[]) => [
            type,
            typePool.filter((weapon: any) => weapon.type === type).length
          ]).filter(
            ([type]: [string, number], index: number, all: [string, number][]) =>
              all.findIndex(([value]) => value === type) === index
          )
        )
      };
    };

    const getSelectedValues = (inputs: Element[]) =>
      inputs.filter((input) => (input as HTMLInputElement).checked).map((input) => (input as HTMLInputElement).value);

    const render = () => {
      const query = searchInput instanceof HTMLInputElement ? searchInput.value.trim().toLowerCase() : "";
      const selectedRarities = getSelectedValues(rarityInputs);
      const selectedTypes = getSelectedValues(typeInputs);
      const sortValue = sortInputs.find((i) => (i as HTMLInputElement).checked)
        ? (sortInputs.find((i) => (i as HTMLInputElement).checked) as HTMLInputElement).value
        : "name-asc";
      const filterCounts = getFilterCounts({
        query,
        selectedRarities,
        selectedTypes
      });

      const filtered = weapons.filter((weapon: any) => {
        const matchesQuery =
          query.length === 0 ||
          weapon.name.toLowerCase().includes(query) ||
          weapon.type.toLowerCase().includes(query);
        const matchesRarity =
          selectedRarities.length === 0 || selectedRarities.includes(weapon.rarity);
        const matchesType = selectedTypes.length === 0 || selectedTypes.includes(weapon.type);

        return matchesQuery && matchesRarity && matchesType;
      });

      filtered.sort((left: any, right: any) => {
        switch (sortValue) {
          case "name-desc":
            return compareText(right.name, left.name);
          case "baseDamage-desc":
            return compareNumber((right.stats.baseDamage ?? -1), (left.stats.baseDamage ?? -1));
          case "baseDamage-asc":
            return compareNumber((left.stats.baseDamage ?? -1), (right.stats.baseDamage ?? -1));
          case "finalDamage-desc":
            return compareNumber((right.stats.finalDamage ?? -1), (left.stats.finalDamage ?? -1));
          case "finalDamage-asc":
            return compareNumber((left.stats.finalDamage ?? -1), (right.stats.finalDamage ?? -1));
          case "rarity-asc":
            return compareRarity(left.rarity, right.rarity);
          case "rarity-desc":
            return compareRarity(right.rarity, left.rarity);
          default:
            return compareText(left.name, right.name);
        }
      });

      if (countNode) {
        countNode.textContent = String(filterCounts.total);
      }

      rarityCountNodes.forEach((node) => {
        if (!(node instanceof HTMLElement)) {
          return;
        }

        const value = node.dataset.filterValue ?? "";
        node.textContent = String(filterCounts.rarityCounts[value] ?? 0);
      });

      typeCountNodes.forEach((node) => {
        if (!(node instanceof HTMLElement)) {
          return;
        }

        const value = node.dataset.filterValue ?? "";
        node.textContent = String(filterCounts.typeCounts[value] ?? 0);
      });

      if (results instanceof HTMLElement) {
        results.innerHTML = filtered
          .map(
            (weapon: any) => `
              <article class="group flex flex-col gap-4 rounded-xl border border-border bg-card p-5 shadow-sm transition-all hover:border-primary/30 hover:shadow-md">
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <p class="font-sans text-[0.7rem] font-medium uppercase tracking-widest text-primary">
                      ${weapon.typeLabel}
                    </p>
                    <a href="/weapon/${weapon.slug}" class="mt-1 block font-serif text-xl font-semibold text-card-foreground transition-colors hover:text-primary">
                      ${weapon.name}
                    </a>
                  </div>
                  <span class="shrink-0 rounded-full bg-primary/10 px-2.5 py-1 font-sans text-[0.7rem] font-medium uppercase tracking-wider text-primary">
                    ${weapon.rarity}
                  </span>
                </div>
                <dl class="grid grid-cols-2 gap-3">
                  <div class="border-t border-border pt-3">
                    <dt class="font-sans text-xs uppercase text-muted-foreground">Base</dt>
                    <dd class="mt-0.5 text-lg font-semibold text-card-foreground">${weapon.stats.baseDamage ?? "N/A"}</dd>
                  </div>
                  <div class="border-t border-border pt-3">
                    <dt class="font-sans text-xs uppercase text-muted-foreground">Final</dt>
                    <dd class="mt-0.5 text-lg font-semibold text-card-foreground">${weapon.stats.finalDamage ?? "N/A"}</dd>
                  </div>
                  <div class="border-t border-border pt-3">
                    <dt class="font-sans text-xs uppercase text-muted-foreground">Type</dt>
                    <dd class="mt-0.5 text-sm text-card-foreground">${weapon.type}</dd>
                  </div>
                  <div class="border-t border-border pt-3">
                    <dt class="font-sans text-xs uppercase text-muted-foreground">Page</dt>
                    <dd class="mt-0.5 text-sm text-card-foreground">Full details</dd>
                  </div>
                </dl>
                <a href="/weapon/${weapon.slug}"
                   class="mt-auto inline-flex items-center gap-1 font-sans text-sm font-medium text-primary transition-colors hover:text-primary/80">
                  Open weapon page
                  <svg class="size-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m9 5 7 7-7 7" />
                  </svg>
                </a>
              </article>
            `
          )
          .join("");
      }
    };

    searchInput?.addEventListener("input", render);
    rarityInputs.forEach((input) => input.addEventListener("change", render));
    typeInputs.forEach((input) => input.addEventListener("change", render));

    // Dropdown toggle logic
    function setupDropdown(name: string, inputs: Element[], labelSelector?: string) {
      const btn = root.querySelector(`[data-dropdown-btn="${name}"]`);
      const panel = root.querySelector(`[data-dropdown-panel="${name}"]`);
      const countBadge = root.querySelector(`[data-dropdown-count="${name}"]`);
      if (!btn || !panel) return;

      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        // Close other dropdowns
        root.querySelectorAll("[data-dropdown-panel]").forEach((p) => {
          if (p !== panel) p.classList.add("hidden");
        });
        panel.classList.toggle("hidden");
      });

      panel.addEventListener("click", (e) => e.stopPropagation());

      // Update badge count on change
      inputs.forEach((input) => {
        input.addEventListener("change", () => {
          if (countBadge) {
            const count = inputs.filter((i) => (i as HTMLInputElement).checked).length;
            if (count > 0) {
              countBadge.textContent = String(count);
              countBadge.classList.remove("hidden");
            } else {
              countBadge.classList.add("hidden");
            }
          }
          // For sort dropdown, update the label
          if (labelSelector) {
            const selected = inputs.find((i) => (i as HTMLInputElement).checked) as HTMLInputElement;
            const label = root.querySelector(labelSelector);
            if (label && selected) {
              label.textContent = selected.parentElement?.textContent?.trim() ?? "";
            }
          }
          render();
        });
      });
    }

    setupDropdown("rarity", rarityInputs);
    setupDropdown("type", typeInputs);
    setupDropdown("sort", sortInputs, "[data-sort-label]");

    // Close dropdowns when clicking outside
    document.addEventListener("click", () => {
      root.querySelectorAll("[data-dropdown-panel]").forEach((p) => p.classList.add("hidden"));
    });
  }
</script>
