---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Mounts | Crimson Desert">
  <section class="py-12">
    <a href="/" class="mb-6 inline-flex items-center gap-1 font-sans text-sm text-primary transition-colors hover:text-primary/80">
      ← Back to home
    </a>
    <span class="mb-3 block text-4xl">🐴</span>
    <h1 class="font-serif text-4xl font-bold tracking-tight text-foreground sm:text-5xl">Mounts</h1>
    <p class="mt-3 max-w-xl text-muted-foreground">Horses, camels, and other rideable creatures.</p>
  </section>

  <div class="rounded-2xl border border-border bg-card p-8 shadow-sm">
    <div class="flex flex-col items-center gap-3 py-8 text-center">
      <div class="rounded-full bg-primary/10 p-4">
        <svg class="size-8 text-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
      </div>
      <h2 class="font-sans text-xl font-semibold text-card-foreground">Coming Soon</h2>
      <p class="max-w-md text-sm text-muted-foreground">
        Category data hookup comes after the first data pipeline pass. Check back soon for full mount listings.
      </p>
    </div>
  </div>
</BaseLayout>
