---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CategoryDirectory from "../../components/CategoryDirectory.astro";
import { loadJsonArray } from "../../lib/categories";

const mounts = await loadJsonArray("data/mounts.json");
---

<BaseLayout title="Mounts | Crimson Desert">
  <CategoryDirectory
    title="Mounts"
    eyebrow="Travel roster"
    description="Horses, camels, and other rideable creatures."
    items={mounts}
    emptyLabel="Mount data is not populated yet."
  />
</BaseLayout>
