---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getStaticWeaponPaths,
  getWeaponBySlug,
  loadWeapons,
} from "../../lib/weapons";

export async function getStaticPaths() {
  return getStaticWeaponPaths(await loadWeapons());
}

const weapons = await loadWeapons();
const weapon = getWeaponBySlug(weapons, Astro.params.name ?? "");

if (!weapon) {
  return Astro.redirect("/weapons");
}

const hasSockets = weapon.sockets !== "N/A";
const hasRefinement = weapon.refinement.length > 0;
const hasMaterials = weapon.craftingMaterials.length > 0;
---

<BaseLayout
  title={`${weapon.name} | Crimson Desert`}
  description={weapon.description}
>
  <style>
    @import url("https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@400;500;600;700&display=swap");

    .weapon-page {
      --wp-display: "Cormorant Garamond", Georgia, serif;
      --wp-body: "DM Sans", system-ui, sans-serif;
    }

    /* --- Hero banner --- */
    .weapon-hero {
      position: relative;
      overflow: hidden;
      border-radius: 1.25rem;
      padding: 3.5rem 2.5rem 3rem;
      background:
        radial-gradient(
          ellipse 70% 50% at 80% 20%,
          color-mix(in srgb, var(--primary) 14%, transparent),
          transparent
        ),
        radial-gradient(
          ellipse 50% 60% at 10% 80%,
          color-mix(in srgb, var(--primary) 8%, transparent),
          transparent
        ),
        var(--card);
      border: 1px solid var(--border);
    }
    .weapon-hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%239C92AC' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
      pointer-events: none;
    }

    .weapon-hero__back {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      font-family: var(--wp-body);
      font-size: 0.8125rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--muted-foreground);
      text-decoration: none;
      transition: color 0.2s;
    }
    .weapon-hero__back:hover {
      color: var(--primary);
    }
    .weapon-hero__back svg {
      width: 1rem;
      height: 1rem;
      transition: transform 0.2s;
    }
    .weapon-hero__back:hover svg {
      transform: translateX(-3px);
    }

    .weapon-hero__heading-group {
      margin-top: 2rem;
      display: flex;
      flex-wrap: wrap;
      align-items: flex-end;
      justify-content: space-between;
      gap: 1.5rem;
    }

    .weapon-hero__type-label {
      font-family: var(--wp-body);
      font-size: 0.6875rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--primary);
      margin-bottom: 0.5rem;
    }

    .weapon-hero__name {
      font-family: var(--wp-display);
      font-size: clamp(2.75rem, 5vw, 4.5rem);
      font-weight: 700;
      line-height: 1.05;
      letter-spacing: -0.02em;
      color: var(--card-foreground);
      margin: 0;
    }

    .weapon-hero__description {
      font-family: var(--wp-display);
      font-style: italic;
      font-size: 1.125rem;
      line-height: 1.6;
      color: var(--muted-foreground);
      max-width: 38rem;
      margin-top: 1rem;
    }

    .weapon-hero__rarity {
      font-family: var(--wp-body);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 0.5rem 1.25rem;
      border: 2px solid var(--primary);
      color: var(--primary);
      border-radius: 999px;
      white-space: nowrap;
    }

    /* --- Stat ribbon --- */
    .stat-ribbon {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
      gap: 1px;
      background: var(--border);
      border-radius: 1rem;
      overflow: hidden;
      margin-top: 1.5rem;
    }
    .stat-ribbon__cell {
      background: var(--card);
      padding: 1.5rem 1.75rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .stat-ribbon__label {
      font-family: var(--wp-body);
      font-size: 0.625rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: var(--muted-foreground);
    }
    .stat-ribbon__value {
      font-family: var(--wp-display);
      font-size: 2rem;
      font-weight: 700;
      color: var(--card-foreground);
      line-height: 1;
    }
    .stat-ribbon__value--accent {
      color: var(--primary);
    }

    /* --- Main columns --- */
    .weapon-columns {
      display: grid;
      gap: 1.5rem;
      margin-top: 1.5rem;
    }
    @media (min-width: 1024px) {
      .weapon-columns {
        grid-template-columns: 1fr 1fr;
      }
    }

    /* --- Panel --- */
    .panel {
      border: 1px solid var(--border);
      border-radius: 1.25rem;
      background: var(--card);
      overflow: hidden;
    }
    .panel__header {
      padding: 1.5rem 1.75rem 0;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .panel__icon {
      width: 2rem;
      height: 2rem;
      border-radius: 0.5rem;
      background: color-mix(in srgb, var(--primary) 12%, transparent);
      display: grid;
      place-items: center;
      color: var(--primary);
      flex-shrink: 0;
    }
    .panel__icon svg {
      width: 1rem;
      height: 1rem;
    }
    .panel__title {
      font-family: var(--wp-display);
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--card-foreground);
      margin: 0;
    }
    .panel__body {
      padding: 1.25rem 1.75rem 1.75rem;
    }
    .panel__empty {
      font-family: var(--wp-body);
      font-size: 0.875rem;
      color: var(--muted-foreground);
      font-style: italic;
      padding: 0.5rem 0;
    }

    /* --- Sockets grid --- */
    .socket-counts {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.75rem;
      margin-bottom: 1.25rem;
    }
    .socket-count {
      text-align: center;
      padding: 1rem;
      border-radius: 0.75rem;
      background: color-mix(in srgb, var(--primary) 5%, var(--background));
      border: 1px solid color-mix(in srgb, var(--primary) 12%, var(--border));
    }
    .socket-count__number {
      font-family: var(--wp-display);
      font-size: 1.75rem;
      font-weight: 700;
      color: var(--primary);
      line-height: 1;
    }
    .socket-count__label {
      font-family: var(--wp-body);
      font-size: 0.625rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--muted-foreground);
      margin-top: 0.375rem;
    }

    /* --- Socket stat list --- */
    .socket-stat-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .socket-stat-list li {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.625rem 0;
      border-bottom: 1px solid
        color-mix(in srgb, var(--border) 60%, transparent);
      font-family: var(--wp-body);
      font-size: 0.875rem;
    }
    .socket-stat-list li:last-child {
      border-bottom: none;
    }
    .socket-stat-list__name {
      color: var(--card-foreground);
    }
    .socket-stat-list__slug {
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--primary);
      background: color-mix(in srgb, var(--primary) 10%, transparent);
      padding: 0.2rem 0.5rem;
      border-radius: 0.25rem;
    }

    /* --- Material rows --- */
    .material-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .material-list li {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.75rem 0;
      border-bottom: 1px solid
        color-mix(in srgb, var(--border) 60%, transparent);
      font-family: var(--wp-body);
      font-size: 0.875rem;
    }
    .material-list li:last-child {
      border-bottom: none;
    }
    .material-list__name {
      color: var(--card-foreground);
      font-weight: 500;
    }
    .material-list__qty {
      font-weight: 700;
      font-variant-numeric: tabular-nums;
      color: var(--primary);
      min-width: 2.5rem;
      text-align: right;
    }

    /* --- Refinement table --- */
    .refinement-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      font-family: var(--wp-body);
      font-size: 0.8125rem;
    }
    .refinement-table thead th {
      font-size: 0.625rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--muted-foreground);
      padding: 0.625rem 1rem;
      text-align: left;
      background: color-mix(in srgb, var(--primary) 5%, transparent);
      border-bottom: 1px solid var(--border);
      white-space: nowrap;
    }
    .refinement-table thead th:first-child {
      border-radius: 0.5rem 0 0 0;
    }
    .refinement-table thead th:last-child {
      border-radius: 0 0.5rem 0 0;
    }
    .refinement-table tbody tr {
      transition: background 0.15s;
    }
    .refinement-table tbody tr:hover {
      background: color-mix(in srgb, var(--primary) 3%, transparent);
    }
    .refinement-table tbody td {
      padding: 0.625rem 1rem;
      border-bottom: 1px solid
        color-mix(in srgb, var(--border) 50%, transparent);
      color: var(--card-foreground);
      vertical-align: top;
    }
    .refinement-table tbody tr:last-child td {
      border-bottom: none;
    }
    .refinement-table__level {
      font-weight: 700;
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--primary);
      white-space: nowrap;
    }
    .refinement-table__chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.375rem;
    }
    .refinement-table__chip {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      padding: 0.2rem 0.5rem;
      border-radius: 0.25rem;
      font-size: 0.75rem;
      white-space: nowrap;
      background: color-mix(in srgb, var(--primary) 8%, var(--background));
      border: 1px solid color-mix(in srgb, var(--border) 60%, transparent);
    }
    .refinement-table__chip-label {
      color: var(--card-foreground);
    }
    .refinement-table__chip-value {
      font-weight: 700;
      color: var(--card-foreground);
    }
    .refinement-table__chip--mat .refinement-table__chip-value {
      color: var(--primary);
    }
    .refinement-table__none {
      color: var(--muted-foreground);
      font-style: italic;
      font-size: 0.75rem;
    }
    /* responsive: stack on very small screens */
    @media (max-width: 639px) {
      .refinement-table,
      .refinement-table thead,
      .refinement-table tbody,
      .refinement-table tr,
      .refinement-table th,
      .refinement-table td {
        display: block;
      }
      .refinement-table thead {
        display: none;
      }
      .refinement-table tbody tr {
        border: 1px solid var(--border);
        border-radius: 0.75rem;
        padding: 0.75rem 1rem;
        margin-bottom: 0.625rem;
        background: color-mix(in srgb, var(--background) 60%, var(--card));
      }
      .refinement-table tbody td {
        padding: 0.375rem 0;
        border-bottom: none;
      }
      .refinement-table tbody td::before {
        content: attr(data-label);
        display: block;
        font-size: 0.5625rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--muted-foreground);
        margin-bottom: 0.25rem;
      }
    }

    /* --- Source footer --- */
    .source-bar {
      margin-top: 1.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding: 1rem 1.5rem;
      border-radius: 1rem;
      border: 1px solid var(--border);
      background: var(--card);
    }
    .source-bar__label {
      font-family: var(--wp-body);
      font-size: 0.625rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: var(--muted-foreground);
    }
    .source-bar__link {
      font-family: var(--wp-body);
      font-size: 0.8125rem;
      font-weight: 600;
      color: var(--primary);
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      transition: opacity 0.2s;
    }
    .source-bar__link:hover {
      opacity: 0.75;
    }
    .source-bar__link svg {
      width: 0.875rem;
      height: 0.875rem;
    }

    /* --- Entrance animations --- */
    @keyframes weapon-fade-up {
      from {
        opacity: 0;
        transform: translateY(1.25rem);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    .animate-in {
      animation: weapon-fade-up 0.55s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    .delay-1 {
      animation-delay: 0.08s;
    }
    .delay-2 {
      animation-delay: 0.16s;
    }
    .delay-3 {
      animation-delay: 0.24s;
    }
    .delay-4 {
      animation-delay: 0.32s;
    }
    .delay-5 {
      animation-delay: 0.4s;
    }
  </style>

  <div class="weapon-page">
    <!-- ░░ HERO ░░ -->
    <div class="weapon-hero animate-in">
      <a
        href="/weapons"
        class="weapon-hero__back"
        data-weapon-directory-back-link
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2.5"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"></path>
        </svg>
        All Weapons
      </a>

      <div class="weapon-hero__heading-group">
        <div>
          <p class="weapon-hero__type-label">{weapon.typeLabel}</p>
          <h1 class="weapon-hero__name">{weapon.name}</h1>
          {
            weapon.description && (
              <p class="weapon-hero__description">
                &ldquo;{weapon.description}&rdquo;
              </p>
            )
          }
        </div>
        <span class="weapon-hero__rarity">{weapon.rarity}</span>
      </div>
      <!-- ░░ SOURCE ░░ -->
      <a
        href={weapon.source.url}
        target="_blank"
        rel="noreferrer"
        class="source-bar__link"
      >
        View original page
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
          ></path>
        </svg>
      </a>
    </div>

    <!-- ░░ STAT RIBBON ░░ -->
    <div class="stat-ribbon animate-in delay-1">
      <div class="stat-ribbon__cell">
        <span class="stat-ribbon__label">Base Damage</span>
        <span class="stat-ribbon__value">{weapon.stats.baseDamage ?? "—"}</span>
      </div>
      <div class="stat-ribbon__cell">
        <span class="stat-ribbon__label">Final Damage</span>
        <span class="stat-ribbon__value stat-ribbon__value--accent"
          >{weapon.stats.finalDamage ?? "—"}</span
        >
      </div>
      <div class="stat-ribbon__cell">
        <span class="stat-ribbon__label">Type</span>
        <span class="stat-ribbon__value">{weapon.type}</span>
      </div>
    </div>

    <!-- ░░ TWO-COLUMN PANELS ░░ -->
    <div class="weapon-columns">
      <!-- LEFT: Crafting Materials -->
      <div class="panel animate-in delay-3">
        <div class="panel__header">
          <div class="panel__icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125"
              ></path>
            </svg>
          </div>
          <h2 class="panel__title">Crafting Materials</h2>
        </div>
        <div class="panel__body">
          {
            hasMaterials ? (
              <ul class="material-list">
                {weapon.craftingMaterials.map((mat) => (
                  <li>
                    <span class="material-list__name">{mat.name}</span>
                    <span class="material-list__qty">
                      &times;{mat.quantity}
                    </span>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="panel__empty">
                No crafting materials listed for this weapon.
              </p>
            )
          }
        </div>
      </div>
      <!-- RIGHT: Sockets -->
      <div class="panel animate-in delay-2">
        <div class="panel__header">
          <div class="panel__icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
            </svg>
          </div>
          <h2 class="panel__title">Sockets</h2>
        </div>
        <div class="panel__body">
          {
            !hasSockets ? (
              <p class="panel__empty">
                No socket data available for this weapon.
              </p>
            ) : (
              <>
                <div class="socket-counts">
                  <div class="socket-count">
                    <div class="socket-count__number">
                      {weapon.sockets.filled}
                    </div>
                    <div class="socket-count__label">Filled</div>
                  </div>
                  <div class="socket-count">
                    <div class="socket-count__number">
                      {weapon.sockets.total}
                    </div>
                    <div class="socket-count__label">Total</div>
                  </div>
                  <div class="socket-count">
                    <div class="socket-count__number">
                      {weapon.sockets.empty}
                    </div>
                    <div class="socket-count__label">Empty</div>
                  </div>
                </div>
                {weapon.sockets.stats.length > 0 ? (
                  <ul class="socket-stat-list">
                    {weapon.sockets.stats.map((s) => (
                      <li>
                        <span class="socket-stat-list__name">{s.name}</span>
                        <span class="socket-stat-list__slug">{s.slug}</span>
                      </li>
                    ))}
                  </ul>
                ) : (
                  <p class="panel__empty">No socket stats listed.</p>
                )}
              </>
            )
          }
        </div>
      </div>

      
    </div>

    <!-- ░░ REFINEMENT (FULL-WIDTH) ░░ -->
    <div class="panel animate-in delay-4" style="margin-top:1.5rem;">
      <div class="panel__header">
        <div class="panel__icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"
            ></path>
          </svg>
        </div>
        <h2 class="panel__title">Refinement</h2>
      </div>
      <div class="panel__body">
        {
          hasRefinement ? (
            <table class="refinement-table">
              <thead>
                <tr>
                  <th>Level</th>
                  <th>Stats</th>
                  <th>Materials</th>
                </tr>
              </thead>
              <tbody>
                {weapon.refinement.map((row) => (
                  <tr>
                    <td data-label="Level">
                      <span class="refinement-table__level">{row.level}</span>
                    </td>
                    <td data-label="Stats">
                      {row.stats.length > 0 ? (
                        <div class="refinement-table__chips">
                          {row.stats.map((stat) => (
                            <span class="refinement-table__chip">
                              <span class="refinement-table__chip-label">
                                {stat.label}
                              </span>
                              <span class="refinement-table__chip-value">
                                {stat.value}
                              </span>
                            </span>
                          ))}
                        </div>
                      ) : (
                        <span class="refinement-table__none">—</span>
                      )}
                    </td>
                    <td data-label="Materials">
                      {row.materials.length > 0 ? (
                        <div class="refinement-table__chips">
                          {row.materials.map((mat) => (
                            <span class="refinement-table__chip refinement-table__chip--mat">
                              <span class="refinement-table__chip-label">
                                {mat.name}
                              </span>
                              <span class="refinement-table__chip-value">
                                &times;{mat.quantity}
                              </span>
                            </span>
                          ))}
                        </div>
                      ) : (
                        <span class="refinement-table__none">None</span>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          ) : (
            <p class="panel__empty">
              No refinement data listed for this weapon.
            </p>
          )
        }
      </div>
    </div>
  </div>

  <script>
    const directoryBackLink = document.querySelector(
      "[data-weapon-directory-back-link]",
    );
    const rememberedDirectoryState = window.sessionStorage.getItem(
      "weapons-directory-state",
    );

    if (
      directoryBackLink instanceof HTMLAnchorElement &&
      typeof rememberedDirectoryState === "string"
    ) {
      directoryBackLink.href =
        rememberedDirectoryState.length > 0
          ? `/weapons?${rememberedDirectoryState}`
          : "/weapons";
    }
  </script>
</BaseLayout>
