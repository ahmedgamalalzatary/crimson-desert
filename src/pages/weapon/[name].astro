---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getStaticWeaponPaths,
  getWeaponBySlug,
  loadWeapons,
} from "../../lib/weapons";
import "../../styles/weapon.css";

export async function getStaticPaths() {
  return getStaticWeaponPaths(await loadWeapons());
}

const weapons = await loadWeapons();
const weapon = getWeaponBySlug(weapons, Astro.params.name ?? "");

if (!weapon) {
  return Astro.redirect("/weapons");
}

const hasSockets = weapon.sockets !== "N/A";
const hasRefinement = weapon.refinement.length > 0;
const hasMaterials = weapon.craftingMaterials.length > 0;
---

<BaseLayout
  title={`${weapon.name} | Crimson Desert`}
  description={weapon.description}
>
  <div class="weapon-page">
    <!-- ░░ HERO ░░ -->
    <div class="weapon-hero animate-in">
      <a
        href="/weapons"
        class="weapon-hero__back"
        data-weapon-directory-back-link
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2.5"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"></path>
        </svg>
        All Weapons
      </a>

      <div class="weapon-hero__heading-group">
        <div>
          <p class="weapon-hero__type-label">{weapon.typeLabel}</p>
          <h1 class="weapon-hero__name">{weapon.name}</h1>
          {
            weapon.description && (
              <p class="weapon-hero__description">
                &ldquo;{weapon.description}&rdquo;
              </p>
            )
          }
        </div>
        <span class="weapon-hero__rarity">{weapon.rarity}</span>
      </div>
      <!-- ░░ SOURCE ░░ -->
      <a
        href={weapon.source.url}
        target="_blank"
        rel="noreferrer"
        class="source-bar__link"
      >
        View original page
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
          ></path>
        </svg>
      </a>
    </div>

    <!-- ░░ STAT RIBBON ░░ -->
    <div class="stat-ribbon animate-in delay-1">
      <div class="stat-ribbon__cell">
        <span class="stat-ribbon__label">Base Damage</span>
        <span class="stat-ribbon__value">{weapon.stats.baseDamage ?? "—"}</span>
      </div>
      <div class="stat-ribbon__cell">
        <span class="stat-ribbon__label">Final Damage</span>
        <span class="stat-ribbon__value stat-ribbon__value--accent"
          >{weapon.stats.finalDamage ?? "—"}</span
        >
      </div>
      <div class="stat-ribbon__cell">
        <span class="stat-ribbon__label">Type</span>
        <span class="stat-ribbon__value">{weapon.type}</span>
      </div>
    </div>

    <!-- ░░ TWO-COLUMN PANELS ░░ -->
    <div class="weapon-columns">
      <!-- LEFT: Crafting Materials -->
      <div class="panel animate-in delay-3">
        <div class="panel__header">
          <div class="panel__icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125"
              ></path>
            </svg>
          </div>
          <h2 class="panel__title">Crafting Materials</h2>
        </div>
        <div class="panel__body">
          {
            hasMaterials ? (
              <ul class="material-list">
                {weapon.craftingMaterials.map((mat) => (
                  <li>
                    <span class="material-list__name">{mat.name}</span>
                    <span class="material-list__qty">
                      &times;{mat.quantity}
                    </span>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="panel__empty">
                No crafting materials listed for this weapon.
              </p>
            )
          }
        </div>
      </div>
      <!-- RIGHT: Sockets -->
      <div class="panel animate-in delay-2">
        <div class="panel__header">
          <div class="panel__icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
            </svg>
          </div>
          <h2 class="panel__title">Sockets</h2>
        </div>
        <div class="panel__body">
          {
            !hasSockets ? (
              <p class="panel__empty">
                No socket data available for this weapon.
              </p>
            ) : (
              <>
                <div class="socket-counts">
                  <div class="socket-count">
                    <div class="socket-count__number">
                      {weapon.sockets.filled}
                    </div>
                    <div class="socket-count__label">Filled</div>
                  </div>
                  <div class="socket-count">
                    <div class="socket-count__number">
                      {weapon.sockets.total}
                    </div>
                    <div class="socket-count__label">Total</div>
                  </div>
                  <div class="socket-count">
                    <div class="socket-count__number">
                      {weapon.sockets.empty}
                    </div>
                    <div class="socket-count__label">Empty</div>
                  </div>
                </div>
                {weapon.sockets.stats.length > 0 ? (
                  <ul class="socket-stat-list">
                    {weapon.sockets.stats.map((s) => (
                      <li>
                        <span class="socket-stat-list__name">{s.name}</span>
                        <span class="socket-stat-list__slug">{s.slug}</span>
                      </li>
                    ))}
                  </ul>
                ) : (
                  <p class="panel__empty">No socket stats listed.</p>
                )}
              </>
            )
          }
        </div>
      </div>

      
    </div>

    <!-- ░░ REFINEMENT (FULL-WIDTH) ░░ -->
    <div class="panel animate-in delay-4" style="margin-top:1.5rem;">
      <div class="panel__header">
        <div class="panel__icon">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"
            ></path>
          </svg>
        </div>
        <h2 class="panel__title">Refinement</h2>
      </div>
      <div class="panel__body">
        {
          hasRefinement ? (
            <table class="refinement-table">
              <thead>
                <tr>
                  <th>Level</th>
                  <th>Stats</th>
                  <th>Materials</th>
                </tr>
              </thead>
              <tbody>
                {weapon.refinement.map((row) => (
                  <tr>
                    <td data-label="Level">
                      <span class="refinement-table__level">{row.level}</span>
                    </td>
                    <td data-label="Stats">
                      {row.stats.length > 0 ? (
                        <div class="refinement-table__chips">
                          {row.stats.map((stat) => (
                            <span class="refinement-table__chip">
                              <span class="refinement-table__chip-label">
                                {stat.label}
                              </span>
                              <span class="refinement-table__chip-value">
                                {stat.value}
                              </span>
                            </span>
                          ))}
                        </div>
                      ) : (
                        <span class="refinement-table__none">—</span>
                      )}
                    </td>
                    <td data-label="Materials">
                      {row.materials.length > 0 ? (
                        <div class="refinement-table__chips">
                          {row.materials.map((mat) => (
                            <span class="refinement-table__chip refinement-table__chip--mat">
                              <span class="refinement-table__chip-label">
                                {mat.name}
                              </span>
                              <span class="refinement-table__chip-value">
                                &times;{mat.quantity}
                              </span>
                            </span>
                          ))}
                        </div>
                      ) : (
                        <span class="refinement-table__none">None</span>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          ) : (
            <p class="panel__empty">
              No refinement data listed for this weapon.
            </p>
          )
        }
      </div>
    </div>
  </div>

  <script>
    import "../../lib/weapon.js";
  </script>
</BaseLayout>
