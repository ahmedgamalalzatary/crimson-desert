---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CategoryDirectory from "../../components/CategoryDirectory.astro";
import { loadJsonArray } from "../../lib/categories";

const questsMain = await loadJsonArray("data/quests-main.json");
const questsFaction = await loadJsonArray("data/quests-faction.json");
---

<BaseLayout title="Quests | Crimson Desert">
  <div class="grid gap-8">
    <CategoryDirectory
      title="Main Quests"
      eyebrow="Story path"
      description="Main story quest lines and chapters."
      items={questsMain}
      emptyLabel="Main quest data is not populated yet."
    />
    <CategoryDirectory
      title="Faction Quests"
      eyebrow="Faction board"
      description="Faction quest lines and repeatable objectives."
      items={questsFaction}
      emptyLabel="Faction quest data is not populated yet."
    />
  </div>
</BaseLayout>
