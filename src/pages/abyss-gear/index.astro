---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CategoryDirectory from "../../components/CategoryDirectory.astro";
import { loadJsonArray } from "../../lib/categories";

const abyssGear = await loadJsonArray("data/abyss-gear.json");
---

<BaseLayout title="Abyss Gear | Crimson Desert">
  <CategoryDirectory
    title="Abyss Gear"
    eyebrow="Rare drops"
    description="Abyss equipment and dungeon variants."
    items={abyssGear}
    emptyLabel="Abyss gear data is not populated yet."
  />
</BaseLayout>
