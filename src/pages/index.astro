---
import BaseLayout from "../layouts/BaseLayout.astro";

const categories = [
  { href: "/weapons", label: "Weapons", icon: "⚔️", desc: "Swords, bows, staves and more" },
  { href: "/armors", label: "Armors", icon: "🛡️", desc: "Chest, helm, gloves and boots" },
  { href: "/shields", label: "Shields", icon: "🔰", desc: "Block and parry gear" },
  { href: "/abyss-gear", label: "Abyss Gear", icon: "🌀", desc: "Rare abyss dungeon drops" },
  { href: "/bosses", label: "Bosses", icon: "👹", desc: "World and dungeon bosses" },
  { href: "/mounts", label: "Mounts", icon: "🐴", desc: "Horses, camels and more" },
  { href: "/quests", label: "Quests", icon: "📜", desc: "Main and faction quest lines" },
];
---

<BaseLayout title="Crimson Desert">
  <section class="py-12 sm:py-20">
    <p class="mb-3 font-sans text-sm font-medium uppercase tracking-widest text-primary">
      Static game reference
    </p>
    <h1 class="font-serif text-5xl font-bold leading-[0.95] tracking-tight text-foreground sm:text-7xl">
      Crimson Desert
    </h1>
    <p class="mt-4 max-w-xl text-lg text-muted-foreground">
      Aggregated item, boss, mount, and quest data built from multiple public sources.
    </p>
  </section>

  <section class="grid grid-cols-1 gap-4 pb-12 sm:grid-cols-2 lg:grid-cols-4">
    {categories.map((cat) => (
      <a
        href={cat.href}
        class="group flex flex-col justify-between rounded-xl border border-border bg-card p-5 shadow-sm transition-all duration-150 hover:-translate-y-0.5 hover:border-primary/40 hover:shadow-md"
      >
        <span class="mb-4 text-3xl">{cat.icon}</span>
        <div>
          <h2 class="font-sans text-lg font-semibold text-card-foreground group-hover:text-primary">
            {cat.label}
          </h2>
          <p class="mt-1 text-sm text-muted-foreground">{cat.desc}</p>
        </div>
        <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-primary opacity-0 transition-opacity group-hover:opacity-100">
          Browse →
        </span>
      </a>
    ))}
  </section>
</BaseLayout>
