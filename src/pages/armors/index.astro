---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CategoryDirectory from "../../components/CategoryDirectory.astro";
import { loadJsonArray } from "../../lib/categories";

const armors = await loadJsonArray("data/armors.json");
---

<BaseLayout title="Armors | Crimson Desert">
  <CategoryDirectory
    title="Armors"
    eyebrow="Defensive gear"
    description="Armor pieces, sets, and defensive equipment from the current data pipeline."
    items={armors}
    emptyLabel="Armor data is not populated yet."
  />
</BaseLayout>
