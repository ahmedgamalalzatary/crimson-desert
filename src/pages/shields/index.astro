---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CategoryDirectory from "../../components/CategoryDirectory.astro";
import { loadJsonArray } from "../../lib/categories";

const shields = await loadJsonArray("data/shields.json");
---

<BaseLayout title="Shields | Crimson Desert">
  <CategoryDirectory
    title="Shields"
    eyebrow="Defensive gear"
    description="Shields for blocking, parrying, and defensive builds."
    items={shields}
    emptyLabel="Shield data is not populated yet."
  />
</BaseLayout>
