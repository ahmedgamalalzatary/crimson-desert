---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CategoryDirectory from "../../components/CategoryDirectory.astro";
import { loadJsonArray } from "../../lib/categories";

const bosses = await loadJsonArray("data/bosses.json");
---

<BaseLayout title="Bosses | Crimson Desert">
  <CategoryDirectory
    title="Bosses"
    eyebrow="Encounter log"
    description="World bosses, dungeon bosses, and loot references."
    items={bosses}
    emptyLabel="Boss data is not populated yet."
  />
</BaseLayout>
